# ---------------------------------------------------------
# This file is managed by Ansible, manual changes will be
# overwritten on the next run.
# ---------------------------------------------------------

{% set is_root_domain = (item.url.split('.') | length == 2) %}

# Redirection HTTP vers HTTPS (domaine nu)

server {
    listen 80;
    listen [::]:80;

    server_name {{ item.url }};

    return 301 https://{{ item.url }}$request_uri;
}

{% if is_root_domain %}
# Redirection HTTP vers HTTPS (www.<domaine>) si domaine racine

server {
    listen 80;
    listen [::]:80;

    server_name www.{{ item.url }};

    return 301 https://www.{{ item.url }}$request_uri;
}
{% endif %}

{% if is_root_domain %}
# Vhost SSL "nu" uniquement pour rediriger vers www si domaine racine

server {
    listen 443 ssl;
    listen [::]:443 ssl;

    http2 on;

    server_name {{ item.url }};

    {% for forbidden_item in nginx_forbiden_list %}
        include /etc/nginx/custom.d/forbidden-{{ forbidden_item }}.conf;
    {% endfor %}

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # Content Security Policy
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' {{ item.url }}; style-src 'self'; img-src 'self' {{ item.url }}; font-src 'self'; connect-src 'self'; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;" always;

    # LetsEncrypt Config
    include /etc/letsencrypt/options-ssl-nginx.conf;

    # LetsEncrypt SSL Certificates & Keys
    ssl_certificate     /etc/letsencrypt/live/{{ item.url }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ item.url }}/privkey.pem;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://www.{{ item.url }}$request_uri;
}
{% endif %}

{# Vhost principal SSL :
   - si domaine racine → www.<domaine>
   - sinon → domaine tel quel (sous-domaines, etc.)
#}
server {
    listen 443 ssl;
    listen [::]:443 ssl;

    http2 on;

    {% if is_root_domain %}
    server_name www.{{ item.url }};
    {% else %}
    server_name {{ item.url }};
    {% endif %}

    root /var/www/{{ item.url }};
    index index.html index.htm;
    disable_symlinks off;

    # Fichiers de logs:
    error_log  /var/log/nginx/{{ item.url }}/error.log;
    access_log /var/log/nginx/{{ item.url }}/access.log;

    location / {
        try_files $uri $uri/ =404;
    }

    {% for forbidden_item in nginx_forbiden_list %}
        include /etc/nginx/custom.d/forbidden-{{ forbidden_item }}.conf;
    {% endfor %}

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    # X-Frame-Options
    add_header X-Frame-Options SAMEORIGIN;

    {% set csp_host = 'www.' + item.url if is_root_domain else item.url %}

    # Content Security Policy
    add_header Content-Security-Policy "
    default-src 'self';
    script-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://www.google.com https://www.gstatic.com;
    style-src 'self' 'unsafe-inline';
    img-src 'self' https://{{ csp_host }} https://i.ytimg.com data:;
    font-src 'self' data:;
    connect-src 'self';
    frame-src https://www.youtube.com https://www.youtube-nocookie.com;
    object-src 'none';
    base-uri 'self';
    form-action 'self';
    upgrade-insecure-requests;
    " always;

    # X-Content-Type-Options
    add_header X-Content-Type-Options nosniff;

    # LetsEncrypt Config
    include /etc/letsencrypt/options-ssl-nginx.conf;

    # LetsEncrypt SSL Certificates & Keys
    ssl_certificate     /etc/letsencrypt/live/{{ item.url }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ item.url }}/privkey.pem;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;
}
